export BLOGX_QINIU_ACCESS_KEY='******'
export BLOGX_QINIU_SECRET_KEY='******'
export BLOGX_QINIU_BUCKET='your-bucket'
export BLOGX_QINIU_DOMAIN='https://cdn.example.com'
export BLOGX_QINIU_REGION='z2'
export BLOGX_QINIU_PREFIX='myblogx'
export BLOGX_QINIU_MAX_SIZE_MB='5'
export BLOGX_QINIU_TOKEN_EXPIRY_SEC='1800'
export BLOGX_QINIU_CALLBACK_URL='https://api.example.com/api/images/qiniu/callback'

# 运行时默认站点开关
export BLOGX_SITE_MODE='1'
export BLOGX_LOGIN_USERNAME_PASSWORD_ENABLED='true'
export BLOGX_LOGIN_EMAIL_ENABLED='true'
export BLOGX_LOGIN_CAPTCHA_ENABLED='false'
export BLOGX_EMAIL_CODE_TIMEOUT_MIN='5'
export BLOGX_LOGIN_FAIL_WINDOW_MIN='15'
export BLOGX_LOGIN_FAIL_USER_MAX='5'
export BLOGX_LOGIN_FAIL_IP_MAX='20'
export BLOGX_EMAIL_SEND_WINDOW_SEC='60'
export BLOGX_EMAIL_SEND_PER_EMAIL_MAX='1'
export BLOGX_EMAIL_SEND_PER_IP_MAX='10'
export BLOGX_ARTICLE_SKIP_EXAMINING='true'
export BLOGX_COMMENT_SKIP_EXAMINING='true'

# AI
