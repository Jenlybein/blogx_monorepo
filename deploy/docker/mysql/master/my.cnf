[client]
port        = 3306
socket      = /var/run/mysqld/mysqld.sock

[mysqld_safe]
pid-file    = /var/run/mysqld/mysqld.pid
socket      = /var/run/mysqld/mysqld.sock
nice        = 0  # 进程优先级（0为默认，数值越小优先级越高）

[mysqld]
user        = mysql
pid-file    = /var/run/mysqld/mysqld.pid
socket      = /var/run/mysqld/mysqld.sock
port        = 3306
basedir     = /usr
datadir     = /var/lib/mysql
tmpdir      = /tmp
secure-file-priv=/var/lib/mysql-files
lc-messages-dir = /usr/share/mysql

# 基本配置
default-authentication-plugin = mysql_native_password
character-set-server = utf8mb4
collation-server=utf8mb4_unicode_ci
explicit_defaults_for_timestamp=true
lower_case_table_names=1
max_allowed_packet=128M

# 主从复制必要配置
log-bin = mysql-bin
server-id = 1

# binlog 合理配置
binlog_format = ROW           # binlog格式为ROW
sync_binlog = 1               # 1 立刻刷盘(数据安全但性能差) 2 每秒刷盘
expire_logs_days = 7          # binlog保留7天
max_binlog_size = 1G          # 单个binlog文件最大1G
innodb_flush_log_at_trx_commit=1 # 事务提交立即刷盘

# 固定relay log名称，避免容器ID变化导致冲突
relay-log = mysql-relay-bin
relay-log-index = mysql-relay-bin.index

# 允许所有IP连接（生产环境改为具体IP）
bind-address=0.0.0.0

# 开启GTID模式（全局事务标识符，自动配置）
gtid_mode=ON
# 强制GTID一致性（必须，确保所有事务都有GTID）
enforce_gtid_consistency=ON
# （可选，级联复制必须开启）记录GTID到binlog
log_slave_updates=ON