{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": [
    "BLOGX_*",
    "TZ"
  ],
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".output/**",
        ".nuxt/**",
        "bin/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "clear": {
      "cache": false
    }
  }
}
